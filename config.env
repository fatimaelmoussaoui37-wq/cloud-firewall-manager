#!/bin/bash
# Configuration file for SecureWall

# Colors for display
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Thresholds
MAX_SSH_ATTEMPTS=3
TIME_WINDOW=60

# Default authorized ports
AUTHORIZED_PORTS="22 80 443"

# Log files
LOG_DIR="./logs"
FIREWALL_LOG="$LOG_DIR/firewall.log"
INTRUSION_LOG="$LOG_DIR/intrusions.log"

# Whitelist IPs (never block)
WHITELIST_IPS="127.0.0.1 ::1"
